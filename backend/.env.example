# Supabase (obtenha em: https://supabase.com/dashboard → Project Settings → API)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<sua-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<sua-service-role-key>

# Server
PORT=3001
NODE_ENV=development

# CRON (a cada 6 horas)
CRON_PAYMENT_GENERATION="0 */6 * * *"

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:3000

# Evolution API (WhatsApp)
EVOLUTION_API_URL=https://sua-evolution-api.com
EVOLUTION_API_KEY=sua-api-key
EVOLUTION_INSTANCE=nome-da-instancia

# Resend (Email)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=MotoRent Pro <noreply@seudominio.com>

# Abacate Pay (PIX)
ABACATE_PAY_API_KEY=         # API Key do Dashboard Abacate Pay (abacate_live_...)
ABACATE_PAY_WEBHOOK_SECRET=  # String aleatória para validar webhooks
